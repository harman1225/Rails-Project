<h1 class="mb-4">Books</h1>

<%= form_with url: root_path, method: :get, local: true do %>
  <div class="row mb-4">

    <div class="col-md-4">
      <%= text_field_tag :search, params[:search], placeholder: "Search books...", class: "form-control" %>
    </div>

    <div class="col-md-4">
      <%= select_tag :genre,
          options_from_collection_for_select(@genres, :id, :name, params[:genre]),
          include_blank: "All Genres",
          class: "form-control" %>
    </div>

    <div class="col-md-4">
      <%= submit_tag "Search", class: "btn btn-primary w-100" %>
    </div>

  </div>
<% end %>

<hr>

<% if @books.any? %>
  <div class="row">
    <% @books.each do |book| %>
      <div class="col-md-4 mb-4">
        <div class="card p-3 h-100 shadow-sm">

          <h5>
            <%= link_to book.title, book_path(book), class: "text-decoration-none" %>
          </h5>

          <p><strong>Author:</strong> <%= book.author.name %></p>
          <p><strong>Genre:</strong> <%= book.genre.name %></p>

        </div>
      </div>
    <% end %>
  </div>
<% else %>
  <p>No books found</p>
<% end %>

<!-- Pagination -->
<div class="mt-4 d-flex justify-content-center">
  <%= paginate @books %>
</div>