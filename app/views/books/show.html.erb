<h1><%= @book.title %></h1>

<p><strong>Author:</strong> <%= @book.author.name %></p>
<p><strong>Genre:</strong> <%= @book.genre.name %></p>
<p><strong>Year:</strong> <%= @book.year %></p>
<p><%= @book.description %></p>

<h2>Reviews</h2>
<% @book.reviews.each do |review| %>
  <p><%= review.rating %> ⭐ - <%= review.comment %></p>
<% end %>